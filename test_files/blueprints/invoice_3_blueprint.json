  "tables": [
    {
      "table_name": "transactions",
      "description": "Multi-page transaction table containing transaction date, credit amount, debit amount, description, and running balance.",
      "required": true,
      "detection_strategy": {
        "strategy_type": "header_keyword_and_row_pattern",
        "use_detected_tables_if_available": true,
        "fallback_to_line_grouping": true,
        "minimum_header_match_count": 3,
        "allow_multi_page_table": true
      },
      "header_keywords": [
        "date",
        "credit",
        "debit",
        "description",
        "balance"
      ],
      "start_markers": [
        "date credit debit",
        "date credit debit description balance",
        "transaction details"
      ],
      "end_markers": [
        "statement summary",
        "customer service information",
        "business details",
        "total"
      ],
      "columns": [
        {
          "name": "transaction_date",
          "display_name": "Transaction Date",
          "data_type": "date",
          "required": true,
          "possible_headers": [
            "date"
          ],
          "extraction_strategy": {
            "strategy_type": "column_position_or_pattern_mapping",
            "value_pattern": "[0-9]{1,2}-[A-Za-z]{3}",
            "infer_year_from_statement_context": true
          },
          "normalization": {
            "trim": true,
            "parse_date": true,
            "input_date_formats": [
              "DD-MMM",
              "D-MMM"
            ],
            "output_date_format": "YYYY-MM-DD",
            "infer_missing_year": true
          },
          "validation": {
            "required": true,
            "must_be_valid_date": true
          },
          "output_key": "transaction_date"
        },
        {
          "name": "credit_amount",
          "display_name": "Credit Amount",
          "data_type": "money",
          "required": false,
          "possible_headers": [
            "credit"
          ],
          "extraction_strategy": {
            "strategy_type": "column_position_or_context_mapping",
            "value_pattern": "money",
            "use_credit_debit_columns_if_coordinates_available": true,
            "fallback_classify_by_balance_change": true
          },
          "normalization": {
            "parse_money": true,
            "decimal_separator_detection": true,
            "thousand_separator_detection": true
          },
          "validation": {
            "must_be_positive_or_zero": true
          },
          "output_key": "credit_amount"
        },
        {
          "name": "debit_amount",
          "display_name": "Debit Amount",
          "data_type": "money",
          "required": false,
          "possible_headers": [
            "debit"
          ],
          "extraction_strategy": {
            "strategy_type": "column_position_or_context_mapping",
            "value_pattern": "money",
            "use_credit_debit_columns_if_coordinates_available": true,
            "fallback_classify_by_balance_change": true
          },
          "normalization": {
            "parse_money": true,
            "decimal_separator_detection": true,
            "thousand_separator_detection": true
          },
          "validation": {
            "must_be_positive_or_zero": true
          },
          "output_key": "debit_amount"
        },
        {
          "name": "description",
          "display_name": "Description",
          "data_type": "string",
          "required": false,
          "possible_headers": [
            "description"
          ],
          "extraction_strategy": {
            "strategy_type": "column_position_or_text_between_amounts",
            "allow_multiline": true,
            "merge_continuation_lines": true,
            "handle_concatenated_balance_description": true
          },
          "normalization": {
            "trim": true,
            "remove_extra_spaces": true,
            "separate_leading_money_from_description": true,
            "separate_trailing_money_from_description": true
          },
          "validation": {
            "max_length": 500
          },
          "output_key": "description"
        },
        {
          "name": "balance",
          "display_name": "Running Balance",
          "data_type": "money",
          "required": false,
          "possible_headers": [
            "balance"
          ],
          "extraction_strategy": {
            "strategy_type": "column_position_or_rightmost_money_mapping",
            "value_pattern": "money",
            "prefer_rightmost_money_column": true
          },
          "normalization": {
            "parse_money": true,
            "decimal_separator_detection": true,
            "thousand_separator_detection": true
          },
          "validation": {
            "must_be_valid_money": true
          },
          "output_key": "balance"
        }
      ],
      "row_rules": {
        "minimum_columns_per_row": 2,
        "ignore_empty_rows": true,
        "ignore_rows_matching": [
          "date",
          "credit",
          "debit",
          "description",
          "balance",
          "transaction details",
          "statement summary",
          "customer service information",
          "business details"
        ],
        "allow_wrapped_description_rows": true,
        "merge_wrapped_rows_when_no_date_present": true,
        "row_continuation_strategy": "append_to_previous_description",
        "stop_when_end_marker_found": false,
        "multi_page_continuation": true,
        "special_row_patterns": [
          "date followed by one_or_more_money_values",
          "description followed by running_balance",
          "running_balance_concatenated_with_description",
          "final_total_row"
        ]
      },
      "validation": {
        "required": true,
        "minimum_rows": 1,
        "running_balance_should_progress_consistently_when_possible": true,
        "summary_totals_should_match_transaction_sums_when_possible": true,
        "allowed_total_tolerance": 0.1
      },
      "confidence_rules": {
        "base_score": 0.45,
        "increase_if_header_keywords_found": 0.25,
        "increase_if_rows_have_dates": 0.15,
        "increase_if_running_balances_detected": 0.1,
        "increase_if_multi_page_continuation_detected": 0.05,
        "decrease_if_no_header_found": 0.2,
        "decrease_if_rows_are_inconsistent": 0.25
      },
      "fallback_strategy": {
        "enabled": true,
        "fallback_order": [
          "detected_tables_from_normalizer",
          "line_grouping_between_transaction_headers_and_summary_sections",
          "date_money_description_balance_pattern",
          "manual_review"
        ],
        "on_failure": "return_empty_array_with_warning"
      },
      "output_key": "transactions"
    }
  ],
  "data_normalization_rules": {
    "strings": {
      "trim": true,
      "collapse_multiple_spaces": true,
      "remove_invisible_characters": true,
      "split_concatenated_money_and_text": true
    },
    "dates": {
      "standard_output_format": "YYYY-MM-DD",
      "ambiguous_date_policy": "infer_year_from_statement_context_then_warn",
      "supported_formats": [
        "YYYY-MM-DD",
        "DD/MM/YYYY",
        "MM/DD/YYYY",
        "DD-MM-YYYY",
        "DD MMM YYYY",
        "MMM DD YYYY",
        "DD-MMM",
        "D-MMM"
      ]
    },
    "numbers": {
      "decimal_separator_detection": true,
      "thousand_separator_detection": true,
      "negative_number_formats": [
        "-100.00",
        "(100.00)"
      ]
    },
    "money": {
      "preserve_original_text": true,
      "parse_numeric_value": true,
      "extract_currency_if_present": true,
      "rounding_precision": 2,
      "support_space_thousand_separator": true,
      "support_comma_decimal_separator": true
    },
    "currency": {
      "symbol_to_code_map": {
        "$": "USD",
        "€": "EUR",
        "£": "GBP",
        "TND": "TND",
        "د.ت": "TND"
      }
    }
  },
  "validation_rules": {
    "document_level": [
      {
        "rule_id": "required_bank_name",
        "description": "Bank name must be present.",
        "severity": "error",
        "condition": "bank.name is not null"
      },
      {
        "rule_id": "required_account_number",
        "description": "Account number must be present.",
        "severity": "error",
        "condition": "account.account_number is not null"
      },
      {
        "rule_id": "required_business_name",
        "description": "Business name must be present.",
        "severity": "error",
        "condition": "customer.business_name is not null"
      },
      {
        "rule_id": "required_opening_balance",
        "description": "Opening balance must be present and valid.",
        "severity": "error",
        "condition": "summary.opening_balance is valid_money"
      },
      {
        "rule_id": "required_net_balance",
        "description": "Net balance must be present and valid.",
        "severity": "error",
        "condition": "summary.net_balance is valid_money"
      },
      {
        "rule_id": "transactions_present",
        "description": "At least one transaction row should be extracted.",
        "severity": "warning",
        "condition": "transactions.length >= 1"
      },
      {
        "rule_id": "summary_balance_consistency",
        "description": "Opening balance plus total credit minus total debit should approximately match net balance when all values are available.",
        "severity": "warning",
        "condition": "abs((summary.opening_balance + summary.total_credit - summary.total_debit) - summary.net_balance) <= 0.1"
      }
    ],
    "field_level_policy": {
      "missing_required_field": "error",
      "invalid_required_field": "error",
      "missing_optional_field": "info",
      "invalid_optional_field": "warning"
    }
  },
  "confidence_scoring": {
    "enabled": true,
    "score_range": {
      "min": 0,
      "max": 1
    },
    "document_confidence_formula": {
      "required_fields_weight": 0.45,
      "optional_fields_weight": 0.15,
      "table_confidence_weight": 0.3,
      "validation_consistency_weight": 0.1
    },
    "confidence_thresholds": {
      "high": 0.85,
      "medium": 0.65,
      "low": 0.4
    },
    "manual_review_policy": {
      "send_to_review_if_document_confidence_below": 0.7,
      "send_to_review_if_required_field_confidence_below": 0.7,
      "send_to_review_if_validation_errors_exist": true
    }
  },
  "warnings_and_fallback_behavior": {
    "warning_categories": [
      "missing_required_field",
      "missing_optional_field",
      "low_confidence",
      "ambiguous_candidate",
      "validation_failed",
      "ocr_quality_low",
      "table_detection_failed",
      "layout_identity_low",
      "document_type_mismatch",
      "multi_page_table_continuation",
      "concatenated_money_and_text",
      "missing_statement_period"
    ],
    "fallback_policy": {
      "allow_field_fallbacks": true,
      "allow_table_fallbacks": true,
      "allow_formula_based_inference": true,
      "allow_manual_review_marker": true,
      "never_guess_required_values_without_trace": true
    },
    "on_extraction_failure": {
      "return_partial_output": true,
      "include_errors": true,
      "include_warnings": true,
      "include_source_trace": true
    }
  },
  "output_mapping": {
    "output_format": "json",
    "include_metadata": true,
    "include_confidence": true,
    "include_source_trace": true,
    "target_structure": {
      "bank": {
        "name": "fields.bank_name"
      },
      "account": {
        "account_number": "fields.account_number",
        "account_type": "fields.account_type"
      },
      "customer": {
        "business_name": "fields.business_name",
        "business_address": "fields.business_address"
      },
      "summary": {
        "opening_balance": "fields.opening_balance",
        "total_credit": "fields.total_credit",
        "total_debit": "fields.total_debit",
        "net_balance": "fields.net_balance",
        "currency": "fields.currency"
      },
      "transactions": "tables.transactions"
    }
  },
  "source_trace_requirements": {
    "enabled": true,
    "for_each_field_include": [
      "page_number",
      "line_index",
      "raw_text",
      "matched_label",
      "extraction_strategy_used",
      "confidence"
    ],
    "for_each_table_row_include": [
      "page_number",
      "raw_row_text",
      "detected_columns",
      "confidence"
    ]
  },
  "versioning": {
    "blueprint_semver": true,
    "breaking_change_policy": {
      "major": "Changes to required sections, field contract, table contract, or output mapping.",
      "minor": "New optional fields, new strategies, or new validation rules.",
      "patch": "Small corrections to labels, hints, or descriptions."
    },
    "backward_compatibility": {
      "engine_should_reject_unsupported_major_versions": true,
      "engine_may_ignore_unknown_optional_properties": true
    }
  },
  "maintainability_notes": {
    "owner": "data_extraction_team",
    "recommended_review_frequency": "after_each_new_bank_statement_layout",
    "known_limitations": [
      "This blueprint is not compatible with invoice-only extraction unless the engine supports multiple document families.",
      "The normalized text order is highly irregular and may separate transaction dates, descriptions, credits, debits, and balances.",
      "Some balances are concatenated with descriptions, so preprocessing must split money values from text.",
      "Credit/debit classification may require coordinates or balance-delta logic when plain text order is insufficient.",
      "Dates appear without a year, so the engine must infer the statement year from external metadata or mark dates as partial."
    ],
    "change_log": [
      {
        "version": "1.0.0",
        "date": "2026-05-26",
        "changes": [
          "Initial reusable blueprint generated for Dreamland-style multi-page bank statement layout."
        ]
      }
    ]
  }
}