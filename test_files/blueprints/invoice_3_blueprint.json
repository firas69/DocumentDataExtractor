{
  "blueprint_metadata": {
    "blueprint_id": "bank_statement_dreamland_layout_v1",
    "blueprint_name": "Dreamland National Bank Statement Layout Blueprint",
    "blueprint_version": "1.0.0",
    "schema_version": "1.0.0",
    "status": "active",
    "created_by": "document_automation_architect",
    "created_at": "2026-05-26",
    "last_updated_at": "2026-05-26",
    "description": "Reusable blueprint for extracting structured data from a two-page bank statement containing business details, statement summary, account balances, transaction details, credit/debit amounts, and running balances.",
    "intended_engine_version": ">=0.1.0",
    "language": "en",
    "notes": [
      "This blueprint is for bank statement documents, not supplier invoices.",
      "An invoice-only extraction engine should reject this document before attempting invoice field extraction.",
      "The normalized text order is noisy; transaction rows may appear split across dates, descriptions, amounts, and balances."
    ]
  },
  "document_family": {
    "family": "financial_statement",
    "document_type": "bank_statement",
    "supported_variants": [
      "business_bank_statement",
      "checking_account_statement",
      "current_account_statement",
      "multi_page_statement"
    ],
    "unsupported_variants": [
      "supplier_invoice",
      "tax_invoice",
      "commercial_invoice",
      "purchase_order",
      "bill_of_lading",
      "receipt_only"
    ],
    "expected_document_characteristics": {
      "is_pdf": true,
      "may_be_scanned": true,
      "may_have_multiple_pages": true,
      "may_contain_tables": true,
      "may_contain_totals_section": true,
      "may_contain_tax_section": false
    }
  },
  "layout_identity": {
    "layout_id": "dreamland_bank_statement_layout",
    "layout_name": "Dreamland Multi-Page Bank Statement Layout",
    "layout_description": "Recognizes a bank statement layout using bank, account, statement summary, balance, credit/debit, and transaction-detail keywords.",
    "identity_strategy": "keyword_and_layout_signature",
    "required_keywords": [
      "bank statement",
      "statement summary",
      "transaction details",
      "opening balance",
      "total credit",
      "total debit",
      "net balance"
    ],
    "optional_keywords": [
      "business details",
      "account type",
      "account number",
      "business name",
      "business address",
      "date",
      "credit",
      "debit",
      "description",
      "balance",
      "customer service information"
    ],
    "negative_keywords": [
      "invoice number",
      "invoice date",
      "subtotal",
      "tax",
      "vat",
      "amount due",
      "bill of lading",
      "bol number",
      "purchase order"
    ],
    "layout_signatures": {
      "page_count_range": {
        "min": 1,
        "max": 10
      },
      "expected_sections": [
        "bank_info",
        "customer_service_info",
        "business_details",
        "statement_summary",
        "transaction_details"
      ],
      "common_label_patterns": [
        "Bank Statement",
        "Statement Summary",
        "Transaction Details",
        "Date Credit Debit",
        "Description",
        "Balance",
        "Opening Balance",
        "Total Credit",
        "Total Debit",
        "Net Balance",
        "Business Details",
        "Account Type",
        "Account Number",
        "Business Name",
        "Business Address"
      ]
    },
    "minimum_identity_confidence": 0.75,
    "on_identity_failure": {
      "action": "reject_blueprint_for_document",
      "message": "The document does not match the expected bank statement layout strongly enough."
    }
  },
  "normalizer_assumptions": {
    "input_representation": "normalized_document",
    "required_normalized_inputs": [
      "pages",
      "lines",
      "text"
    ],
    "optional_normalized_inputs": [
      "blocks",
      "tables",
      "coordinates",
      "font_metadata",
      "ocr_confidence"
    ],
    "line_object_contract": {
      "required_properties": [
        "page_number",
        "line_index",
        "text"
      ],
      "optional_properties": [
