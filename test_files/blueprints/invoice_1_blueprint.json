        {
          "name": "package_type",
          "display_name": "Package Type",
          "data_type": "string",
          "required": false,
          "possible_headers": [
            "pkg type",
            "package type",
            "packaging"
          ],
          "extraction_strategy": {
            "strategy_type": "column_position_or_header_mapping"
          },
          "normalization": {
            "trim": true,
            "remove_extra_spaces": true
          },
          "validation": {
            "max_length": 80
          },
          "output_key": "package_type"
        },
        {
          "name": "description",
          "display_name": "Description",
          "data_type": "string",
          "required": true,
          "possible_headers": [
            "description",
            "item description",
            "goods description"
          ],
          "extraction_strategy": {
            "strategy_type": "column_position_or_header_mapping",
            "allow_multiline": true,
            "merge_continuation_lines": true
          },
          "normalization": {
            "trim": true,
            "remove_extra_spaces": true
          },
          "validation": {
            "min_length": 1,
            "max_length": 500
          },
          "output_key": "description"
        },
        {
          "name": "weight_lbs",
          "display_name": "Weight",
          "data_type": "number",
          "required": true,
          "possible_headers": [
            "weight",
            "weight (lbs)",
            "lbs"
          ],
          "extraction_strategy": {
            "strategy_type": "column_position_or_header_mapping",
            "value_pattern": "number"
          },
          "normalization": {
            "parse_number": true,
            "unit": "lbs"
          },
          "validation": {
            "must_be_positive": true
          },
          "output_key": "weight_lbs"
        },
        {
          "name": "freight_class",
          "display_name": "Freight Class",
          "data_type": "string",
          "required": false,
          "possible_headers": [
            "freight class",
            "class"
          ],
          "extraction_strategy": {
            "strategy_type": "column_position_or_header_mapping",
            "value_pattern": "[0-9A-Za-z\\.\\-]+"
          },
          "normalization": {
            "trim": true
          },
          "validation": {
            "max_length": 40
          },
          "output_key": "freight_class"
        },
        {
          "name": "nmfc_code",
          "display_name": "NMFC Code",
          "data_type": "string",
          "required": false,
          "possible_headers": [
            "nmfc code",
            "nmfc"
          ],
          "extraction_strategy": {
            "strategy_type": "column_position_or_header_mapping",
            "value_pattern": "[0-9A-Za-z\\-]+"
          },
          "normalization": {
            "trim": true
          },
          "validation": {
            "max_length": 50
          },
          "output_key": "nmfc_code"
        },
        {
          "name": "dimensions",
          "display_name": "Dimensions",
          "data_type": "string",
          "required": false,
          "possible_headers": [
            "dims",
            "dimensions",
            "dims (l×w×h in)",
            "l×w×h"
          ],
          "extraction_strategy": {
            "strategy_type": "column_position_or_header_mapping",
            "value_pattern": "[0-9]+\\s*[x×]\\s*[0-9]+\\s*[x×]\\s*[0-9]+"
          },
          "normalization": {
            "trim": true,
            "normalize_multiplication_symbol": true,
            "unit": "in"
          },
          "validation": {
            "max_length": 80
          },
          "output_key": "dimensions"
        }
      ],
      "row_rules": {
        "minimum_columns_per_row": 4,
        "ignore_empty_rows": true,
        "ignore_rows_matching": [
          "shipment details",
          "qty",
          "pkg type",
          "description",
          "special instructions",
          "handling notes",
          "total weight"
        ],
        "allow_wrapped_description_rows": true,
        "merge_wrapped_rows_when_no_weight_present": true,
        "row_continuation_strategy": "append_to_previous_description",
        "stop_when_end_marker_found": true
      },
      "validation": {
        "required": true,
        "minimum_rows": 1,
        "sum_weight_should_match_total_weight": true,
        "allowed_weight_tolerance": 1
      },
      "confidence_rules": {
        "base_score": 0.45,
        "increase_if_header_keywords_found": 0.25,
        "increase_if_rows_have_consistent_column_count": 0.15,
        "increase_if_weight_sum_matches_total_weight": 0.15,
        "decrease_if_no_header_found": 0.2,
        "decrease_if_rows_are_inconsistent": 0.2
      },
      "fallback_strategy": {
        "enabled": true,
        "fallback_order": [
          "detected_tables_from_normalizer",
          "line_grouping_between_shipment_details_and_handling_notes",
          "row_pattern_starting_with_quantity",
          "manual_review"
        ],
        "on_failure": "return_empty_array_with_warning"
      },
      "output_key": "shipment.items"
    }
  ],
  "data_normalization_rules": {
    "strings": {
      "trim": true,
      "collapse_multiple_spaces": true,
      "remove_invisible_characters": true
    },
    "dates": {
      "standard_output_format": "YYYY-MM-DD",
      "ambiguous_date_policy": "prefer_document_locale_then_warn",
      "supported_formats": [
        "YYYY-MM-DD",
        "DD/MM/YYYY",
        "MM/DD/YYYY",
        "DD-MM-YYYY",
        "DD MMM YYYY",
        "MMM DD YYYY"
      ]
    },
    "numbers": {
      "decimal_separator_detection": true,
      "thousand_separator_detection": true,
      "negative_number_formats": [
        "-100.00",
        "(100.00)"
      ]
    },
    "money": {
      "preserve_original_text": true,
      "parse_numeric_value": true,
      "extract_currency_if_present": true,
      "rounding_precision": 2
    },
    "currency": {
      "symbol_to_code_map": {
        "$": "USD",
        "€": "EUR",
        "£": "GBP",
        "TND": "TND",
        "د.ت": "TND"
      }
    },
    "weight": {
      "parse_numeric_value": true,
      "extract_unit": true,
      "supported_units": [
        "lbs",
        "lb",
        "kg",
        "kgs"
      ],
      "remove_thousand_separator": true
    }
  },
  "validation_rules": {
    "document_level": [
      {
        "rule_id": "required_bol_number",
        "description": "BOL number must be present.",
        "severity": "error",
        "condition": "bol.bol_number is not null"
      },
      {
        "rule_id": "required_pickup_date",
        "description": "Pickup date must be present and valid.",
        "severity": "error",
        "condition": "bol.pickup_date is valid_date"
      },
      {
        "rule_id": "required_shipper_name",
        "description": "Shipper name must be present.",
        "severity": "error",
        "condition": "shipper.name is not null"
      },
      {
        "rule_id": "required_consignee_name",
        "description": "Consignee name must be present.",
        "severity": "error",
        "condition": "consignee.name is not null"
      },
      {
        "rule_id": "required_carrier_name",
        "description": "Carrier name must be present.",
        "severity": "error",
        "condition": "carrier.name is not null"
      },
      {
        "rule_id": "shipment_items_present",
        "description": "At least one shipment detail row should be extracted.",
        "severity": "warning",
        "condition": "shipment.items.length >= 1"
      },
      {
        "rule_id": "shipment_weight_consistency",
        "description": "Sum of shipment item weights should approximately match total weight when both values are available.",
        "severity": "warning",
        "condition": "abs(sum(shipment.items.weight_lbs) - shipment.total_weight.value) <= 1"
      }
    ],
    "field_level_policy": {
      "missing_required_field": "error",
      "invalid_required_field": "error",
      "missing_optional_field": "info",
      "invalid_optional_field": "warning"
    }
  },
  "confidence_scoring": {
    "enabled": true,
    "score_range": {
      "min": 0,
      "max": 1
    },
    "document_confidence_formula": {
      "required_fields_weight": 0.5,
      "optional_fields_weight": 0.15,
      "table_confidence_weight": 0.25,
      "validation_consistency_weight": 0.1
    },
    "confidence_thresholds": {
      "high": 0.85,
      "medium": 0.7,
      "low": 0.4
    },
    "manual_review_policy": {
      "send_to_review_if_document_confidence_below": 0.7,
      "send_to_review_if_required_field_confidence_below": 0.7,
      "send_to_review_if_validation_errors_exist": true
    }
  },
  "warnings_and_fallback_behavior": {
    "warning_categories": [
      "missing_required_field",
      "missing_optional_field",
      "low_confidence",
      "ambiguous_candidate",
      "validation_failed",
      "ocr_quality_low",
      "table_detection_failed",
      "layout_identity_low",
      "document_type_mismatch"
    ],
    "fallback_policy": {
      "allow_field_fallbacks": true,
      "allow_table_fallbacks": true,
      "allow_formula_based_inference": true,
      "allow_manual_review_marker": true,
      "never_guess_required_values_without_trace": true
    },
    "on_extraction_failure": {
      "return_partial_output": true,
      "include_errors": true,
      "include_warnings": true,
      "include_source_trace": true
    }
  },
  "output_mapping": {
    "output_format": "json",
    "include_metadata": true,
    "include_confidence": true,
    "include_source_trace": true,
    "target_structure": {
      "bol": {
        "bol_number": "fields.bol_number",
        "po_reference_number": "fields.po_reference_number",
        "pickup_date": "fields.pickup_date",
        "pro_number": "fields.pro_number"
      },
      "shipper": {
        "name": "fields.shipper_name"
      },
      "consignee": {
        "name": "fields.consignee_name"
      },
      "carrier": {
        "name": "fields.carrier_name"
      },
      "shipment": {
        "declared_value": "fields.declared_value",
        "total_weight": "fields.total_weight",
        "handling_notes": "fields.handling_notes",
        "items": "tables.shipment_details"
      }
    }
  },
  "source_trace_requirements": {
    "enabled": true,
    "for_each_field_include": [
      "page_number",
      "line_index",
      "raw_text",
      "matched_label",
      "extraction_strategy_used",
      "confidence"
    ],
    "for_each_table_row_include": [
      "page_number",
      "raw_row_text",
      "detected_columns",
      "confidence"
    ]
  },
  "versioning": {
    "blueprint_semver": true,
    "breaking_change_policy": {
      "major": "Changes to required sections, field contract, table contract, or output mapping.",
      "minor": "New optional fields, new strategies, or new validation rules.",
      "patch": "Small corrections to labels, hints, or descriptions."
    },
    "backward_compatibility": {
      "engine_should_reject_unsupported_major_versions": true,
      "engine_may_ignore_unknown_optional_properties": true
    }
  },
  "maintainability_notes": {
    "owner": "data_extraction_team",
    "recommended_review_frequency": "after_each_new_bol_layout",
    "known_limitations": [
      "This blueprint is not compatible with invoice-only extraction unless the engine supports multiple document families.",
      "Shipment detail extraction depends on consistent row ordering because the normalized document may not expose true table coordinates.",
      "Rows with long descriptions may require continuation-line merging.",
      "OCR errors in BOL number, PRO number, NMFC code, or dimensions can reduce confidence."
    ],
    "change_log": [
      {
        "version": "1.0.0",
        "date": "2026-05-26",
        "changes": [
          "Initial Bill of Lading blueprint generated from the provided normalized document representation."
        ]
      }
    ]
  }
}