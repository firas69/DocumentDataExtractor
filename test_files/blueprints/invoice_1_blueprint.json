{
  "blueprint_metadata": {
    "blueprint_id": "bol_swifttrack_layout_v1",
    "blueprint_name": "Bill of Lading Extraction Blueprint - Standard Logistics Layout",
    "blueprint_version": "1.0.0",
    "schema_version": "1.0.0",
    "status": "active",
    "created_by": "document_automation_architect",
    "created_at": "2026-05-26",
    "last_updated_at": "2026-05-26",
    "description": "Reusable blueprint for extracting structured data from a standard Bill of Lading document with shipper, consignee, carrier, shipment details, declared value, handling notes, total weight, and signature sections.",
    "intended_engine_version": ">=0.1.0",
    "language": "en",
    "notes": [
      "This blueprint is for Bill of Lading documents, not supplier invoices.",
      "The document should be rejected by an invoice-only extraction engine unless BOL documents are explicitly supported.",
      "The blueprint describes extraction rules and must not be treated as extracted output."
    ]
  },
  "document_family": {
    "family": "logistics_document",
    "document_type": "bill_of_lading",
    "supported_variants": [
      "standard_bol",
      "non_negotiable_bol",
      "freight_bol",
      "carrier_bol"
    ],
    "unsupported_variants": [
      "supplier_invoice",
      "tax_invoice",
      "commercial_invoice",
      "purchase_order",
      "receipt",
      "packing_slip_only"
    ],
    "expected_document_characteristics": {
      "is_pdf": true,
      "may_be_scanned": true,
      "may_have_multiple_pages": false,
      "may_contain_tables": true,
      "may_contain_totals_section": false,
      "may_contain_tax_section": false,
      "may_contain_signature_section": true,
      "may_contain_legal_terms": true
    }
  },
  "layout_identity": {
    "layout_id": "standard_bol_logistics_layout",
    "layout_name": "Standard Bill of Lading Logistics Layout",
    "layout_description": "Recognizes a Bill of Lading layout using BOL-specific labels, shipment parties, shipment details, handling notes, total weight, and signatures.",
    "identity_strategy": "keyword_and_section_signature",
    "required_keywords": [
      "bill of lading",
      "bol number",
      "shipper",
      "consignee",
      "carrier",
      "shipment details"
    ],
    "optional_keywords": [
      "original, not negotiable",
      "po / reference number",
      "pickup date",
      "pro number",
      "declared value",
      "total weight",
      "signatures",
      "shipper signature",
      "carrier signature",
      "consignee signature"
    ],
    "negative_keywords": [
      "invoice number",
      "invoice date",
      "subtotal",
      "tax",
      "vat",
      "amount due",
      "balance due",
      "grand total"
    ],
    "layout_signatures": {
      "page_count_range": {
        "min": 1,
        "max": 3
      },
      "expected_sections": [
        "document_header",
        "bol_identifiers",
        "shipper_info",
        "consignee_info",
        "carrier_info",
        "shipment_details",
        "handling_notes",
        "total_weight",
        "legal_terms",
        "signatures"
      ],
      "common_label_patterns": [
        "BOL NUMBER",
        "PO / REFERENCE NUMBER",
        "PICKUP DATE",
        "PRO NUMBER",
        "SHIPPER (FROM)",
        "CONSIGNEE (TO)",
        "CARRIER",
        "DECLARED VALUE",
        "SHIPMENT DETAILS",
        "TOTAL WEIGHT",
        "SIGNATURES"
      ]
    },
    "minimum_identity_confidence": 0.75,
    "on_identity_failure": {
      "action": "reject_blueprint_for_document",
      "message": "The document does not match the expected Bill of Lading layout strongly enough."
    }
  },
  "normalizer_assumptions": {
    "input_representation": "normalized_document",
    "required_normalized_inputs": [
      "pages",
      "lines",
      "text"
    ],
    "optional_normalized_inputs": [
      "blocks",
      "tables",
      "coordinates",
      "font_metadata",
      "ocr_confidence"
    ],
    "line_object_contract": {
      "required_properties": [
        "page_number",
        "line_index",
        "text"
      ],
      "optional_properties": [
        "x_min",
        "y_min",
        "x_max",
        "y_max",
        "block_id",
        "ocr_confidence"
      ]
    },
    "page_numbering": "1_based",
    "text_ordering_assumption": "top_to_bottom_left_to_right",
    "ocr_assumptions": {
      "ocr_may_be_used": true,
      "ocr_errors_expected": true,
      "common_ocr_confusions": [
        {
          "from": "O",
          "to": "0"
        },
        {
          "from": "I",
          "to": "1"
        },
        {
          "from": "S",
          "to": "5"
        }
      ]
    },
    "preprocessing_expectations": {
      "trim_whitespace": true,
      "normalize_unicode": true,
      "preserve_line_breaks": true,
      "preserve_page_numbers": true,
      "do_not_translate_content": true
    }
  },
  "global_extraction_settings": {
    "default_language": "en",
    "supported_languages": [
      "en"
    ],
    "case_sensitive_matching": false,
    "accent_sensitive_matching": false,
    "currency_detection": true,
    "date_detection": true,
    "number_detection": true,
    "multi_page_extraction": true,
    "allow_partial_extraction": true,
    "minimum_document_confidence": 0.7,
    "minimum_required_field_confidence": 0.7,
    "minimum_optional_field_confidence": 0.5,
    "fail_on_missing_required_fields": false,
    "return_extraction_warnings": true,
    "return_field_confidence": true,
    "return_source_trace": true
  },
  "fields": [
    {
      "name": "bol_number",
      "display_name": "BOL Number",
      "description": "Unique Bill of Lading identifier assigned to the shipment document.",
      "data_type": "string",
      "required": true,
      "possible_labels": [
        "bol number",
        "bill of lading number",
        "b/l number"
      ],
      "extraction_strategy": {
        "strategy_type": "label_value",
        "label_position": [
          "next_line",
          "same_line",
          "right_of_label"
        ],
        "value_pattern": "[A-Za-z0-9\\-\\/]+",
        "max_search_distance_lines": 2,
        "stop_words": [
          "po",
          "reference",
          "pickup date",
          "pro number"
        ]
      },
      "location_hint": {
        "preferred_pages": [
          1
        ],
        "preferred_section": "bol_identifiers",
        "relative_position": "top_left_or_top_center"
      },
      "normalization": {
        "trim": true,
        "remove_label_text": true,
        "remove_extra_spaces": true,
        "uppercase": false
      },
      "validation": {
        "required": true,
        "min_length": 3,
        "max_length": 80,
        "regex": "^[A-Za-z0-9][A-Za-z0-9\\-\\/]*$",
        "reject_values": [
          "bol number",
          "bill of lading",
          "date"
        ]
      },
      "confidence_rules": {
        "base_score": 0.5,
        "increase_if_label_found": 0.3,
        "increase_if_value_matches_pattern": 0.15,
        "increase_if_in_expected_location": 0.1,
        "decrease_if_multiple_candidates": 0.15
      },
      "fallback_strategy": {
        "enabled": true,
        "fallback_order": [
          "top_identifier_after_bol_keyword",
          "regex_near_bill_of_lading_keyword",
          "manual_review"
        ],
        "on_failure": "return_null_with_warning"
      },
      "output_key": "bol.bol_number"
    },
    {
